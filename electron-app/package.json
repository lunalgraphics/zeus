{
    "name": "lunalgraphics-zeus",
    "productName": "Zeus",
    "description": "Lightning and electricity effects",
    "author": {
        "name": "Lunal Graphics",
        "url": "https://lunalgraphics.com",
        "email": "lunalgraphics@gmail.com"
    },
    "homepage": "https://lunalgraphics.com/about-zeus",
    "version": "5.0.0",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build:linux": "electron-builder --linux",
        "build:darwin": "electron-builder --mac",
        "build:win32": "electron-builder --windows",
        "build": "electron-builder --mac --linux --windows"
    },
    "devDependencies": {
        "electron": "37.1.0",
        "electron-builder": "^26.8.1"
    },
    "files": [
        "main.js",
        "app/**/*"
    ],
    "build": {
        "appId": "com.electron.lunalgraphics-zeus",
        "directories": {
            "buildResources": "resources"
        },
        "files": [
            "main.js",
            "app/**/*"
        ],
        "win": {
            "target": "portable",
            "signAndEditExecutable": false
        },
        "mac": {
            "target": "zip"
        },
        "linux": {
            "target": "deb"
        }
    }
}
